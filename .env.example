# ── Development ─────────────────────────────────────────────────────────────

# Jellyfin server URL used by the Vite dev-server proxy (no trailing slash).
# Only needed for local development; not used in Docker deployments.
# e.g. http://192.168.1.100:8096 or https://jellyfin.example.com
VITE_JELLYFIN_URL=http://localhost:8096

# ── Docker deployment ─────────────────────────────────────────────────────────

# Internal URL of the Jellyfin server reachable from inside the Docker network.
# nginx substitutes this into the /jellyfin/ reverse-proxy block at startup.
# Set this in docker-compose.yml or pass it as an environment variable.
JELLYFIN_INTERNAL_URL=http://jellyfin:8096

# ── GHCR publish (VS Code tasks) ──────────────────────────────────────────────

# Docker image repository used by the build/push tasks.
IMAGE_REPO=ghcr.io/dave01945/jellydl

# GitHub username and personal access token (write:packages scope) for GHCR login.
GHCR_USERNAME=dave01945
GHCR_TOKEN=your_github_pat_here
